<!DOCTYPE html>
<html>
<head>
    <title>Panel Cliente</title>
</head>
<body>
    <h1>Bienvenido, Cliente</h1>

    <h2>Mis cuentas</h2>
    <ul>
        <% cuentas.forEach(cuenta => { %>
            <li>
                <%= cuenta.numero_cuenta %> - 
                <%= cuenta.nombre_tipo %> - 
                Saldo: Q<%= cuenta.saldo %>
            </li>
        <% }) %>
    </ul>
    <a href="/solicitar-credito/<%= 1 %>">
        <button>Solicitar crédito</button>
      </a>
      
    <h2>Mis préstamos</h2>
    <ul>
    
        <% prestamos.forEach(prestamo => { %>
            <li>
                <%= prestamo.nombre_tipo %> - 
                Monto: Q<%= prestamo.monto %> - 
                Saldo: Q<%= prestamo.saldo_pendiente %>
            </li>
        <% }) %>
    </ul>
    <h2>Mis pagos</h2>

<ul>
  <% if (pagos.length === 0) { %>
    <li>No hay pagos registrados</li>
  <% } else { %>
    <% pagos.forEach(pago => { %>
      <li>
        Préstamo #<%= pago.id_prestamo %> -
        Fecha: <%= pago.fecha_pago %> -
        Pagado: Q<%= pago.monto_pagado %> -
        Mora: Q<%= pago.mora %> -
        Saldo restante: Q<%= pago.saldo_restante %>
      </li>
    <% }) %>
  <% } %>
</ul>
</ul>
</body>
</html>