<!DOCTYPE html>
<html>
<head>
  <title>Cliente encontrado</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
      margin: 0;
      padding: 30px;
    }

    .container {
      max-width: 900px;
      margin: auto;
      background: #1e293b;
      padding: 25px;
      border-radius: 12px;
    }

    h1 {
      margin-bottom: 20px;
    }

    p {
      margin: 10px 0;
    }

    .btn {
      display: inline-block;
      padding: 10px 15px;
      background: #3b82f6;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      margin-right: 10px;
      margin-top: 10px;
    }

    .btn:hover {
      background: #2563eb;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Datos del Cliente</h1>

    <p><strong>ID:</strong> <%= cliente.id_cliente %></p>
    <p><strong>Nombre:</strong> <%= cliente.nombre %></p>
    <p><strong>Apellido:</strong> <%= cliente.apellido %></p>
    <p><strong>DPI:</strong> <%= cliente.dpi %></p>
    <p><strong>NIT:</strong> <%= cliente.nit %></p>
    <p><strong>Correo:</strong> <%= cliente.correo %></p>

    <a href="/cliente/<%= cliente.id_cliente %>" class="btn">Ver panel del cliente</a>
    <a href="/colaborador/cuentas/<%= cliente.id_cliente %>" class="btn">Ver cuentas del cliente</a>
    <a href="/colaborador/prestamos/<%= cliente.id_cliente %>" class="btn">Ver préstamos del cliente</a>
    <a href="/solicitar-credito/<%= cliente.id_cliente %>" class="btn">Solicitar crédito</a>
    <a href="/solicitar-cuenta/<%= cliente.id_cliente %>" class="btn">Solicitar cuenta</a>
  </div>
</body>
</html>